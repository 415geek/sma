{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aos.local/schemas/report_schema.json",
  "title": "Report",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "report_type": {
      "type": "string",
      "enum": ["diagnostic", "monthly_strategy", "campaign_brief", "review"]
    },
    "version": { "type": "integer", "minimum": 1, "default": 1 },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "content_markdown": { "type": "string" },
          "evidence_codes": {
            "type": "array",
            "items": { "type": "string", "pattern": "^EV-[0-9]{3,}$" },
            "default": []
          }
        },
        "required": ["title", "content_markdown"]
      }
    },
    "executive_summary": { "type": "string" },
    "key_recommendations": { "type": "array", "items": { "type": "string" }, "default": [] }
  },
  "required": ["report_type", "sections", "executive_summary"]
}

